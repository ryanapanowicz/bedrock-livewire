{
  "$schema": "https://schemas.wp.org/trunk/block.json",
  "apiVersion": 3,
  "name": "theme/post-explorer",
  "version": "1.0.0",
  "title": "Post Explorer",
  "keywords": [
    "livewire",
    "posts",
    "filters"
  ],
  "acf": {
    "blockVersion": 3,
    "autoJsonLd": true,
    "mode": "preview",
    "autoInlineEditing": true,
    "hideFieldsInSidebar": true,
    "expandedEditorButtonText": "Edit Post Explorer"
  },
  "allowedBlocks": [
    "core/paragraph",
    "core/heading"
  ],
  "category": "theme",
  "icon": "screenoptions",
  "description": "A post explorer block with URL-synced filters and animated post results.",
  "example": {},
  "attributes": {
    "style": {
      "type": "object",
      "default": {
        "spacing": {
          "margin": "0px",
          "padding": "0px"
        },
        "typography": {
          "fontSize": "1rem",
          "lineHeight": "1.6"
        },
        "border": {
          "radius": "28px"
        }
      }
    }
  },
  "supports": {
    "align": [
      "wide",
      "full"
    ],
    "anchor": true,
    "color": {
      "background": true,
      "text": true,
      "gradients": true,
      "link": true,
      "heading": true
    },
    "dimensions": {
      "minHeight": true
    },
    "shadow": true,
    "spacing": {
      "margin": true
    },
    "typography": {
      "fontSize": true,
      "lineHeight": true,
      "textAlign": true
    },
    "jsx": true,
    "mode": "edit",
    "html": false
  },
  "textdomain": "sage",
  "style": "file:./style.css"
}
